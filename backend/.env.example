DATABASE_URL=postgresql+asyncpg://farmer_app:farmer_app@localhost:5432/farmer_app
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000
APP_ENV=development
DEBUG=false
ENABLE_DOCS=true
TRUSTED_HOSTS=localhost,127.0.0.1
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_UPLOAD_REQUESTS=10
RATE_LIMIT_MUTATION_REQUESTS=30
LOCAL_UPLOAD_DIR=uploads
MAX_ANIMAL_PHOTO_UPLOAD_BYTES=10485760
ANIMAL_PHOTO_MAX_DIMENSION=2048
ANIMAL_PHOTO_JPEG_QUALITY=82

VET_DOCUMENT_UPLOAD_DIR=private_uploads/vet-documents
VET_DOCUMENT_MAX_UPLOAD_BYTES=10485760
